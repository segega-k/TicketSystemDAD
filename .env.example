# Local Docker Compose defaults for ticket-system-dad

# Postgres
POSTGRES_DB=ticket_system_dad
POSTGRES_USER=ticket_system_dad
POSTGRES_PASSWORD=ticket_system_dad
POSTGRES_PORT=5432

# Backend datasource inside Compose
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/ticket_system_dad
SPRING_DATASOURCE_USERNAME=ticket_system_dad
SPRING_DATASOURCE_PASSWORD=ticket_system_dad
BACKEND_PORT=8080
BACKEND_CONTAINER_PORT=8080

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_CONTAINER_PORT=6379
APP_REDIS_FAIL_CLOSED=true

# JWT RS256 PEM keys. Run `make jwt-keys` to create these files.
JWT_RSA_PRIVATE_KEY_PATH=/run/secrets/jwt_private.pem
JWT_RSA_PUBLIC_KEY_PATH=/run/secrets/jwt_public.pem
# Alternatively provide inline PEM values through JWT_RSA_PRIVATE_KEY/JWT_RSA_PUBLIC_KEY.

# Frontend
FRONTEND_PORT=3000
VITE_API_BASE_URL=/api/v1

# Optional observability
PROMETHEUS_PORT=9090
