flowchart LR
    subgraph Client
        FE[React 18 + Vite frontend]
    end

    subgraph Edge["nginx 1.27 (TLS, least_conn, ip_hash for /ws)"]
        NX[nginx gateway]
    end

    subgraph App["Spring Boot 3.3 (Java 21)"]
        B1[backend-1]
        B2[backend-2]
    end

    subgraph Data
        PG[(PostgreSQL 16<br/>pgcrypto, pg_trgm)]
        RD[(Redis 7<br/>holds + cache + Pub/Sub)]
    end

    subgraph Batch["Spring Batch (cron)"]
        DS[daily_sales 02:00 UTC]
