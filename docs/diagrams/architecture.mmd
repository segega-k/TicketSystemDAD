        OTC[otel-collector]
        PR[(Prometheus)]
        LO[(Loki)]
        TE[(Tempo)]
        GR[Grafana dashboards]
    end

    FE -- HTTPS / WSS --> NX
    NX -- HTTP --> B1
    NX -- HTTP --> B2
    NX -- WS ip_hash --> B1
    NX -- WS ip_hash --> B2

    B1 <-->|JDBC| PG
    B2 <-->|JDBC| PG
