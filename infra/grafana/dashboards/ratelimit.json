{
  "title": "Rate limiter",
  "uid": "ratelimit",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": {"from": "now-1h", "to": "now"},
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Hold requests vs 429s",
      "gridPos": {"x": 0, "y": 0, "w": 24, "h": 8},
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{uri=\"/api/v1/seats/hold\",method=\"POST\"}[5m]))",
          "legendFormat": "all",
          "refId": "A"
        },
        {
          "expr": "sum(rate(http_server_requests_seconds_count{uri=\"/api/v1/seats/hold\",method=\"POST\",status=\"429\"}[5m]))",
          "legendFormat": "rate-limited (429)",
          "refId": "B"
        }
      ],
      "datasource": {"type": "prometheus", "uid": "Prometheus"}
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Reject ratio (5m)",
      "gridPos": {"x": 0, "y": 8, "w": 6, "h": 5},
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{uri=\"/api/v1/seats/hold\",method=\"POST\",status=\"429\"}[5m])) / clamp_min(sum(rate(http_server_requests_seconds_count{uri=\"/api/v1/seats/hold\",method=\"POST\"}[5m])), 0.001)",
          "refId": "A"
        }
      ],
      "datasource": {"type": "prometheus", "uid": "Prometheus"}
    }
  ]
}
